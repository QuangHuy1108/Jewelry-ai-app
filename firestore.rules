rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════════
    // HELPER FUNCTIONS
    // ═══════════════════════════════════════════════════════════════

    // Check if the request comes from an authenticated user.
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the authenticated user is the document owner.
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Check if the user has an admin custom claim or is in the admins collection.
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.admin == true ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // Check if the current user is blocked by the other party in a chat
    function isBlockedByOtherParty(chatId) {
      return request.auth.uid in get(/databases/$(database)/documents/users/$(
        get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid 
          ? get(/databases/$(database)/documents/chats/$(chatId)).data.sellerId 
          : get(/databases/$(database)/documents/chats/$(chatId)).data.userId
      )).data.get('blockedUsers', []);
    }

    // ═══════════════════════════════════════════════════════════════
    // USERS
    // Owner can read/write their own profile.
    // Admins can read all users and manage them.
    // ═══════════════════════════════════════════════════════════════
    match /users/{userId} {
      // Allow any authenticated user to read profiles (e.g., to see names/avatars in chat)
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['walletBalance', 'role', 'isAdmin', 'membership'])) || isAdmin();
      allow delete: if isAdmin(); // Admins can delete users

      // ── Orders (user-level copy) ──
      match /orders/{orderId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
        allow delete: if false;
      }

      // ── Addresses ──
      match /addresses/{addressId} {
        allow read, write: if isOwner(userId);
      }

      // ── Cart ──
      match /cart/{cartItemId} {
        allow read, write: if isOwner(userId);
      }

      // ── Wishlist / Favorites ──
      match /wishlist/{wishlistItemId} {
        allow read, write: if isOwner(userId);
      }

      // ── Payment Methods (SENSITIVE — owner only, no exceptions) ──
      match /payment_methods/{paymentId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      // ── Wallet Transactions ──
      match /transactions/{txId} {
        allow read: if isOwner(userId);
        allow create: if false;
        allow update: if false; // Transactions are immutable once created
        allow delete: if false; // Cannot delete financial records
      }

      // ── Notifications ──
      match /notifications/{notifId} {
        allow read: if isOwner(userId);
        allow update: if isOwner(userId); // Mark as read
        allow create: if false; // Only Cloud Functions should create notifications
        allow delete: if isOwner(userId);
      }
    }

    // ═══════════════════════════════════════════════════════════════
    // PRODUCTS — Public catalog
    // Anyone can read. Only admins (or Firebase Console / Admin SDK)
    // can write.
    // ═══════════════════════════════════════════════════════════════
    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update, delete: if isAdmin();

      // ── Product Reviews ──
      match /reviews/{reviewId} {
        allow read: if true; // Anyone can read reviews
        allow create: if isAuthenticated()
          && request.resource.data.userId == request.auth.uid;
        allow update: if isAuthenticated()
          && resource.data.userId == request.auth.uid; // Can only edit own review
        allow delete: if isAuthenticated()
          && resource.data.userId == request.auth.uid
          || isAdmin();
      }
    }

    // ═══════════════════════════════════════════════════════════════
    // CATEGORIES — Public catalog metadata
    // ═══════════════════════════════════════════════════════════════
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // BANNERS — Promotional banners for the home screen
    // ═══════════════════════════════════════════════════════════════
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // COUPONS — Promo codes
    // ═══════════════════════════════════════════════════════════════
    match /coupons/{couponId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // TOP-LEVEL ORDERS
    // Users can create and read their own orders.
    // Only admins or Cloud Functions can update order status.
    // ═══════════════════════════════════════════════════════════════
    match /orders/{orderId} {
      allow read: if isAuthenticated()
        && (resource.data.userId == request.auth.uid
            || resource.data.sellerId == request.auth.uid
            || isAdmin());
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
        && (resource.data.sellerId == request.auth.uid || isAdmin());
      allow delete: if false; // Orders are never deleted
    }

    // ═══════════════════════════════════════════════════════════════
    // CHATS — Participant-based access
    // ═══════════════════════════════════════════════════════════════
    match /chats/{chatId} {
      // Get: used when opening a specific chat room directly by ID. We allow resource == null so clients can check if it exists before creating.
      allow get: if isAuthenticated() && (
        resource == null ||
        resource.data.userId == request.auth.uid || 
        resource.data.sellerId == request.auth.uid || 
        request.auth.uid in resource.data.participants
      );

      // List: used when querying all chats for a user. resource == null is not allowed here because it breaks Firestore query evaluation.
      allow list: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        resource.data.sellerId == request.auth.uid || 
        request.auth.uid in resource.data.participants
      );

      // Update, delete: user must be a participant of the existing chat.
      allow update, delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        resource.data.sellerId == request.auth.uid || 
        request.auth.uid in resource.data.participants
      );

      // Create: use request.resource.data (the incoming document), since resource.data doesn't exist yet.
      allow create: if isAuthenticated() && (
        request.resource.data.userId == request.auth.uid ||
        request.auth.uid in request.resource.data.participants
      );

      // Messages subcollection: only chat participants can read/write.
      match /messages/{messageId} {
        allow read: if isAuthenticated() && (
          get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid ||
          get(/databases/$(database)/documents/chats/$(chatId)).data.sellerId == request.auth.uid ||
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
        );
        allow write: if isAuthenticated() && (
          get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid ||
          get(/databases/$(database)/documents/chats/$(chatId)).data.sellerId == request.auth.uid ||
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
        ) && !isBlockedByOtherParty(chatId);
      }
    }

    // ═══════════════════════════════════════════════════════════════
    // ADMINS — Admin user registry
    // Only readable by admins. Writable only via Admin SDK.
    // ═══════════════════════════════════════════════════════════════
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if false; // Managed via Admin SDK / Firebase Console only
    }

    // ═══════════════════════════════════════════════════════════════
    // GLOBAL NOTIFICATIONS — Broadcast announcements
    // ═══════════════════════════════════════════════════════════════
    match /notifications/{notifId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // ANALYTICS — Server-side aggregated data
    // ═══════════════════════════════════════════════════════════════
    match /analytics/{docId} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions write analytics
    }

    // ═══════════════════════════════════════════════════════════════
    // SETTINGS — App-wide configuration
    // ═══════════════════════════════════════════════════════════════
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // SELLER APPLICATIONS — Become-a-seller requests
    // Users can create/read/update their own application.
    // Admins can read all and update status (approve/reject).
    // ═══════════════════════════════════════════════════════════════
    match /seller_applications/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if true;
      allow delete: if false;
    }

    // ═══════════════════════════════════════════════════════════════
    // SELLERS — Approved seller profiles
    // Any authenticated user can read (for seller profile pages).
    // Sellers can ONLY update non-financial fields (name, description, etc).
    // Financial fields (pendingCommission, availableBalance, totalEarnings)
    // are EXCLUSIVELY written by Cloud Functions.
    // ═══════════════════════════════════════════════════════════════
    match /sellers/{sellerId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();

      // Sellers can only update safe profile fields — NOT financial fields
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['pendingCommission', 'availableBalance', 'totalEarnings',
                     'commissionRate', 'totalClicks', 'totalConversions'])
        || isAdmin();

      allow delete: if isAdmin();

      // ── Seller Reviews ──
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if false; // Only via Cloud Functions
        allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      }
    }

    // ═══════════════════════════════════════════════════════════════
    // SELLER TRANSACTIONS — Commission & withdrawal records
    // READ-ONLY for sellers. WRITE-ONLY by Cloud Functions.
    // ═══════════════════════════════════════════════════════════════
    match /seller_transactions/{txId} {
      // Sellers read their own via query filter. Admin reads all.
      allow read: if isAuthenticated();
      allow create, update, delete: if false; // Cloud Functions only
    }

    // ═══════════════════════════════════════════════════════════════
    // PROMO CODES — Seller referral discount codes
    // Authenticated users can read (to validate at checkout).
    // Only admins or Cloud Functions can write.
    // ═══════════════════════════════════════════════════════════════
    match /promo_codes/{codeId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin(); // Cloud Functions bypass rules
    }

    // ═══════════════════════════════════════════════════════════════
    // WITHDRAWALS — Seller payout requests
    // Sellers can read their own. Creation/updates only via Cloud Functions.
    // ═══════════════════════════════════════════════════════════════
    match /withdrawals/{withdrawalId} {
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        || isAdmin();
      allow create, update, delete: if false; // Cloud Functions only
    }

    // ═══════════════════════════════════════════════════════════════
    // REFERRAL CLICKS — Tracking link clicks
    // Sellers can read their own clicks. Writes only via Cloud Functions.
    // ═══════════════════════════════════════════════════════════════
    match /referral_clicks/{clickId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false; // Cloud Functions HTTP endpoint only
    }

    // ═══════════════════════════════════════════════════════════════
    // MEDIA ASSETS — Downloadable images/videos for sellers
    // ═══════════════════════════════════════════════════════════════
    match /media_assets/{assetId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // NOTIFICATION TEMPLATES — Dynamic Content Engine (Phase 2)
    // ═══════════════════════════════════════════════════════════════
    match /notification_templates/{templateId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // NOTIFICATION EVENTS — Telemetry Pipeline (Phase 2)
    // ═══════════════════════════════════════════════════════════════
    match /notification_events/{eventId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if false; // Immutable audit trail
    }

    // ═══════════════════════════════════════════════════════════════
    // SHARES — Link generation and tracking
    // ═══════════════════════════════════════════════════════════════
    match /shares/{shareId} {
      // Anyone can create a share
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      // Users can read their own shares
      allow read: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      // Backend functions update click/conversion metrics, frontend doesn't need to
      allow update, delete: if false; 
    }

    // ═══════════════════════════════════════════════════════════════
    // CATCH-ALL — Deny everything not explicitly matched above.
    // This is critical to prevent unintended data access.
    // ═══════════════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
